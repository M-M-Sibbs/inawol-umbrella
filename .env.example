# === Turso database ===
# Create:  turso db create umbrella
# URL:     turso db show umbrella --url
# Token:   turso db tokens create umbrella
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# === Admin dashboard ===
# Generate the password hash with:
#   npm run admin:hash -- 'your-strong-password-here'
# Then paste the resulting line in here. Use a password of 12+ characters.
ADMIN_PASSWORD_HASH=

# (Optional) Move the admin path off the default /dashboard for extra obscurity.
# If set, your dashboard lives at this URL instead, e.g. /dashboard-x9k2p.
# ADMIN_PATH=/dashboard

# === Optional: media storage on Vercel Blob (recommended for production) ===
# Added automatically when you create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# === Optional: plug a real LLM into the chatbot later ===
# ANTHROPIC_API_KEY=
